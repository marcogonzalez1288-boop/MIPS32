module PC (
    input clk,
    input rst,
    input [31:0] i_dir,       // Esta es tu entrada verdadera
    output reg [31:0] o_dir   // Esta es tu salida verdadera
);

initial begin
    o_dir = 32'd0;
end

always @(posedge clk or posedge rst) begin
    if (rst) begin
        o_dir <= 32'd0;       // <-- CORREGIDO: Usamos o_dir en lugar de PC_OUT
    end else begin
        o_dir <= i_dir;       // <-- CORREGIDO: Asignamos i_dir en lugar de PC_IN
    end
end

endmodule